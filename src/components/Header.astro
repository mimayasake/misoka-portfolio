---
import { base } from '../utils/base';

const pathname = Astro.url.pathname;
const navItems = ["About", "Design", "Writing", "Development", "Planning"];
const links = [
  { href: base, label: "Home" },
  ...navItems.map(label => ({
    label,
    href: `${base}${label.toLowerCase()}`,
  })),
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  class="sticky top-0 z-50 border-b border-[#1d1d1d]/10 bg-white/90 backdrop-blur-md transition-colors"
  transition:persist="site-header"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8">
    <a
      href={base}
      class="text-lg font-semibold tracking-tight text-[#1d1d1d] transition-colors hover:text-[#6822ff]"
    >
      misoka
    </a>

    <!-- デスクトップナビ -->
    <nav class="hidden md:flex items-center gap-x-2 text-sm font-medium">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            data-nav-href={href}
            class:list={[
              "rounded-md px-3 py-1.5 transition-colors",
              isActive(href)
                ? "bg-[#6822ff]/10 text-[#6822ff]"
                : "text-[#1d1d1d]/80 hover:bg-[#1d1d1d]/5 hover:text-[#6822ff]",
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- ハンバーガーボタン（mdより小さい時だけ表示） -->
    <button
      id="menu-btn"
      class="flex md:hidden flex-col justify-center gap-1.5 p-1"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line1"></span>
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line2"></span>
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line3"></span>
    </button>
  </div>

  <!-- モバイルメニュー -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[#1d1d1d]/10 px-5 py-3"
  >
    <nav class="flex flex-col gap-1 text-sm font-medium">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            data-nav-href={href}
            class:list={[
              "rounded-md px-3 py-2 transition-colors",
              isActive(href)
                ? "bg-[#6822ff]/10 text-[#6822ff]"
                : "text-[#1d1d1d]/80 hover:bg-[#1d1d1d]/5 hover:text-[#6822ff]",
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));

      // ×に変化するアニメーション
      if (!isOpen) {
        line1?.classList.add('translate-y-2', 'rotate-45');
        line2?.classList.add('opacity-0');
        line3?.classList.add('-translate-y-2', '-rotate-45');
      } else {
        line1?.classList.remove('translate-y-2', 'rotate-45');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-translate-y-2', '-rotate-45');
      }
    });

    // ページ遷移時にメニューを閉じる
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        line1?.classList.remove('translate-y-2', 'rotate-45');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-translate-y-2', '-rotate-45');
      });
    });
  }

  function updateActiveNav() {
    const pathname = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-href]").forEach((link) => {
      const href = link.getAttribute("data-nav-href") ?? "";
      const active =
        href === "/"
          ? pathname === "/" || pathname === ""
          : pathname === href || pathname.startsWith(href + "/");

      if (active) {
        link.classList.remove("text-[#1d1d1d]/80", "hover:bg-[#1d1d1d]/5", "hover:text-[#6822ff]");
        link.classList.add("bg-[#6822ff]/10", "text-[#6822ff]");
      } else {
        link.classList.remove("bg-[#6822ff]/10", "text-[#6822ff]");
        link.classList.add("text-[#1d1d1d]/80", "hover:bg-[#1d1d1d]/5", "hover:text-[#6822ff]");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('menu-btn');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    line1?.classList.remove('translate-y-2', 'rotate-45');
    line2?.classList.remove('opacity-0');
    line3?.classList.remove('-translate-y-2', '-rotate-45');

    initHeader();
    updateActiveNav();
  });
</script>
