---
import { base } from '../utils/base';

const pathname = Astro.url.pathname;
const navItems = ["About", "Design", "Writing", "Development", "Planning"];
const links = [
  { href: base, label: "Home" },
  ...navItems.map(label => ({
    label,
    href: `${base}${label.toLowerCase()}`,
  })),
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  class="sticky top-0 z-50 border-b border-[#1d1d1d]/10 bg-white transition-colors"
  transition:persist="site-header"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8">
    <a
      href={base}
      class="text-lg font-semibold tracking-tight text-[#1d1d1d] transition-colors hover:text-[#6822ff]"
    >
      misoka
    </a>

    <!-- デスクトップナビ -->
    <nav class="hidden md:flex items-center gap-x-2 text-sm font-medium">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            data-nav-href={href}
            class:list={[
              "rounded-md px-3 py-1.5 transition-colors",
              isActive(href)
                ? "bg-[#6822ff]/10 text-[#6822ff]"
                : "text-[#1d1d1d]/80 hover:bg-[#1d1d1d]/5 hover:text-[#6822ff]",
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- ハンバーガーボタン（mdより小さい時だけ表示） -->
    <button
      id="menu-btn"
      class="flex md:hidden flex-col justify-center gap-1.5 p-1"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line1"></span>
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line2"></span>
      <span class="block h-0.5 w-6 bg-[#1d1d1d] transition-all duration-300" id="line3"></span>
    </button>
  </div>

  <!-- モバイルメニュー -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 right-0 border-t border-[#1d1d1d]/10 bg-white px-5 py-3"
  >
    <nav class="flex flex-col gap-1 text-sm font-medium">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            data-nav-href={href}
            class:list={[
              "rounded-md px-3 py-2 transition-colors",
              isActive(href)
                ? "bg-[#6822ff]/10 text-[#6822ff]"
                : "text-[#1d1d1d]/80 hover:bg-[#1d1d1d]/5 hover:text-[#6822ff]",
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  function getMenuElements() {
    return {
      btn:   document.getElementById('menu-btn'),
      menu:  document.getElementById('mobile-menu'),
      lines: [
        document.getElementById('line1'),
        document.getElementById('line2'),
        document.getElementById('line3'),
      ],
    };
  }

  function closeMenu({ btn, menu, lines }: ReturnType<typeof getMenuElements>) {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    lines[0]?.classList.remove('translate-y-2', 'rotate-45');
    lines[1]?.classList.remove('opacity-0');
    lines[2]?.classList.remove('-translate-y-2', '-rotate-45');
  }

  function initHeader() {
    const els = getMenuElements();
    if (!els.btn || !els.menu) return;

    els.btn.addEventListener('click', () => {
      const isOpen = els.menu!.classList.toggle('hidden');
      els.btn!.setAttribute('aria-expanded', String(!isOpen));

      if (!isOpen) {
        els.lines[0]?.classList.add('translate-y-2', 'rotate-45');
        els.lines[1]?.classList.add('opacity-0');
        els.lines[2]?.classList.add('-translate-y-2', '-rotate-45');
      } else {
        closeMenu(els);
      }
    });

    els.menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => closeMenu(els));
    });
  }

  function updateActiveNav() {
    const pathname = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-href]").forEach((link) => {
      const href = link.getAttribute("data-nav-href") ?? "";
      const active =
        href === "/"
          ? pathname === "/" || pathname === ""
          : pathname === href || pathname.startsWith(href + "/");

      if (active) {
        link.classList.remove("text-[#1d1d1d]/80", "hover:bg-[#1d1d1d]/5", "hover:text-[#6822ff]");
        link.classList.add("bg-[#6822ff]/10", "text-[#6822ff]");
      } else {
        link.classList.remove("bg-[#6822ff]/10", "text-[#6822ff]");
        link.classList.add("text-[#1d1d1d]/80", "hover:bg-[#1d1d1d]/5", "hover:text-[#6822ff]");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    const els = getMenuElements();
    closeMenu(els);

    // transition:persist により同一DOMが再利用されるため、初回のみリスナーを登録する
    if (els.btn && !els.btn.dataset.initialized) {
      initHeader();
      els.btn.dataset.initialized = 'true';
    }

    updateActiveNav();
  });
</script>
