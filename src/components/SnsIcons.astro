---
/** VR・制作向けのよく使うリンク（URLは差し替え可能） */
const items = [
  {
    label: "X (Twitter)",
    href: "https://x.com/m_s_k_VR",
    icon: "x",
  },
  {
    label: "VRChat",
    href: "https://vrchat.com/home/user/usr_0cb68fc4-a05c-4383-99f2-c153501c4584",
    icon: "vrchat",
  },
  {
    label: "GitHub",
    href: "https://github.com/mimayasake",
    icon: "github",
  },
];
---

<ul class="flex items-center gap-3" aria-label="SNSリンク">
  {
    items.map(({ label, href, icon }) => (
      <li>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-[#1d1d1d]/12 text-[#1d1d1d] transition-colors hover:border-[#6822ff]/40 hover:bg-[#6822ff]/5 hover:text-[#6822ff]"
          aria-label={label}
        >
          {icon === "x" && (
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          )}
          {icon === "github" && (
            <svg class="h-[20px] w-[20px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 2C6.477 2 2 6.463 2 11.97c0 4.404 2.865 8.14 6.839 9.458.5.092.682-.216.682-.48 0-.236-.008-.864-.013-1.695-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.107 22 16.373 22 11.969 22 6.463 17.522 2 12 2z"
              />
            </svg>
          )}
          {icon === "vrchat" && (
            <svg class="h-[20px] w-[20px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M3 7h18a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2zM5 12a3 3 0 1 0 6 0 3 3 0 1 0-6 0zM13 12a3 3 0 1 0 6 0 3 3 0 1 0-6 0z"
              />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>
