---
import type { WorkItem } from "../data/works";
import WorkCard from "./WorkCard.astro";

interface Props {
  items: WorkItem[];
  /** セクション見出し */
  heading?: string;
  id?: string;
}

const { items, heading = "Works", id = "works" } = Astro.props;
---

<section class="mx-auto max-w-6xl px-5 py-16 md:px-8 md:py-24" id={id} aria-labelledby={`${id}-heading`}>
  <h2
    id={`${id}-heading`}
    class="mb-10 text-3xl font-bold tracking-tight text-[#1d1d1d] md:mb-12 md:text-4xl"
  >
    <span class="relative inline-block">
      {heading}
      <span
        class="absolute -bottom-1 left-0 h-1 w-1/3 rounded-full bg-[#ff2348]"
        aria-hidden="true"
      ></span>
    </span>
  </h2>
  {
    items.length === 0 ? (
      <p class="rounded-xl border border-dashed border-[#1d1d1d]/15 bg-[#1d1d1d]/[0.02] px-6 py-12 text-center text-[#1d1d1d]/65">
        該当タグの制作物はまだありません。
      </p>
    ) : (
      <div class="work-items grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3">
        {items.map((item) => <WorkCard item={item} />)}
      </div>
    )
  }
</section>
