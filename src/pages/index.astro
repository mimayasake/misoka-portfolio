---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import SnsIcons from "../components/SnsIcons.astro";
import WorkGrid from "../components/WorkGrid.astro";
import { workItems, worksSortedByDateDesc } from "../data/works";

const sortedWorks = worksSortedByDateDesc(workItems);
---

<BaseLayout title="misoka">
  <Header />
  <main>
    <section
      class="relative flex min-h-[100dvh] min-h-screen flex-col justify-between overflow-hidden px-5 pb-8 pt-6 md:px-8 md:pb-10 md:pt-8"
      aria-label="トップ"
    >
      <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_70%_20%,rgba(104,34,255,0.08),transparent_55%),radial-gradient(ellipse_at_30%_80%,rgba(255,35,72,0.06),transparent_50%)]"></div>

      <div class="max-w-6xl flex-1">
        <h1
          class="max-w-[18ch] text-left text-[clamp(2.75rem,8vw,5.5rem)] font-bold leading-[1.05] tracking-tight text-[#1d1d1d]"
          set:html="Hello I'm misoka"
        />
        <p class="mt-6 max-w-xl text-left text-base leading-relaxed text-[#1d1d1d]/75 md:text-lg">
          VRChatを中心に、バーチャル空間でのイベントやワールド制作に取り組んでいます。ビジュアル、文章、実装のいずれもご相談ください。
        </p>
      </div>

      <!-- 中央右下: アバター用スペース（透過PNG等を置く場合はこの枠内を img に差し替え） -->
      <div
        class="pointer-events-none absolute bottom-[24%] left-1/2 w-[min(72vw,260px)] max-w-sm -translate-x-1/2 md:bottom-[20%] md:left-auto md:right-[6%] md:translate-x-0"
        aria-hidden="true"
      >
        <div
          class="flex aspect-[3/4] w-full items-end justify-center rounded-2xl border-2 border-dashed border-[#6822ff]/25 bg-gradient-to-b from-[#6822ff]/5 to-transparent"
        >
          <span class="mb-4 rounded-md bg-white/80 px-3 py-1 text-xs font-medium text-[#6822ff]/80">
            Avatar
          </span>
        </div>
      </div>

      <div class="relative z-10 mt-auto flex w-full max-w-6xl justify-end pt-8">
        <SnsIcons />
      </div>
    </section>

    <WorkGrid items={sortedWorks} heading="Works" id="works" />
  </main>
</BaseLayout>
