---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import SnsIcons from "../components/SnsIcons.astro";
import WorkGrid from "../components/WorkGrid.astro";
import { workItems, worksSortedByDateDesc } from "../data/works";
import { asset } from '../utils/path';

const sortedWorks = worksSortedByDateDesc(workItems);
---

<BaseLayout title="misoka">
  <img id="bg" src={asset("prof-default.png")} alt="Background" class="fixed inset-0 z-0 h-full w-full object-cover" />
  <Header />
  <main class="relative z-10">
    <section
      class="relative z-10 flex min-h-[100dvh] min-h-screen flex-col justify-between overflow-hidden px-5 pb-8 pt-6 md:px-8 md:pb-10 md:pt-8"
      aria-label="トップ"
    >
      <div class="max-w-6xl flex-1">
        <h1
          class="max-w-[18ch] text-left text-[clamp(2.75rem,8vw,5.5rem)] font-bold leading-[1.05] tracking-tight text-[#1d1d1d]"
          set:html="misoka"
        />
        <SnsIcons />
      </div>
    </section>

    <WorkGrid items={sortedWorks} heading="Works" id="works" />
  </main>
</BaseLayout>

<script>
  function updateBg() {
    const bg = document.getElementById('bg');
    if (!bg) return;
    const progress = Math.min(window.scrollY / window.innerHeight, 1);
    bg.style.filter = `blur(${progress * 12}px)`;
  }

  document.addEventListener('astro:page-load', () => {
    window.removeEventListener('scroll', updateBg);
    window.addEventListener('scroll', updateBg);
    updateBg();
  });
</script>
