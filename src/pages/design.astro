---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import WorkGrid from "../components/WorkGrid.astro";
import { worksByTag } from "../data/works";

const items = worksByTag("design");
---

<BaseLayout
  title="Design"
  description="デザインタグの制作物一覧 — ビジュアル、ブランド、空間トーンなど。"
>
  <Header />
  <main>
    <WorkGrid items={items} heading="Design" id="design-works" />
  </main>
</BaseLayout>
